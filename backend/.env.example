
# PhishGuard SOC - Environment Configuration
# Copy this file to .env and update values before running

# Application
APP_NAME=PhishGuard SOC
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_IN_PRODUCTION

# Database
DATABASE_URL=sqlite+aiosqlite:///./phishguard.db

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# File Upload
MAX_FILE_SIZE_MB=25
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# ClamAV (set to true if ClamAV is installed and running)
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# YARA rules path
YARA_RULES_DIR=./rules

# Demo credentials (CHANGE IN PRODUCTION)
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=Admin@123

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
